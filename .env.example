# ============================================================
# ContentPipeline MVP — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#
# Para uso com docker-compose, MONGODB_URI e sobrescrito
# automaticamente (usa o mongo local do compose).
# ============================================================

# --- LLM APIs (obrigatorios — substitua pelas chaves reais) ---
GEMINI_API_KEY=fake-gemini-key-replace-me
DEEPSEEK_API_KEY=fake-deepinfra-key-replace-me
ANTHROPIC_API_KEY=fake-anthropic-key-replace-me

# --- MongoDB (docker-compose sobrescreve automaticamente) ---
MONGODB_URI=mongodb://botuser:botpass@localhost:27017/bot-news?authSource=admin

# --- Dashboard Auth (usuario de teste local) ---
DASHBOARD_USER=admin
DASHBOARD_PASS=admin123

# --- Instagram (opcional — deixe vazio para desabilitar) ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# --- Telegram (opcional — deixe vazio para desabilitar) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- GCP (apenas producao) ---
GCP_PROJECT_ID=
GCP_REGION=southamerica-east1
