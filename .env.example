# ============================================================
# ContentPipeline MVP — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#
# Para uso com docker-compose, MONGODB_URI e sobrescrito
# automaticamente (usa o mongo local do compose).
# ============================================================

# --- LLM APIs (obrigatorios) ---
GEMINI_API_KEY=               # Google AI Studio → aistudio.google.com → Get API Key
DEEPSEEK_API_KEY=             # deepinfra.com → Dashboard → API Keys
ANTHROPIC_API_KEY=            # console.anthropic.com → API Keys

# --- MongoDB ---
MONGODB_URI=mongodb://botuser:botpass@localhost:27017/bot-news?authSource=admin

# --- Dashboard Auth ---
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me

# --- Instagram (opcional — deixe vazio para desabilitar) ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# --- Telegram (opcional — deixe vazio para desabilitar) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- GCP (apenas producao) ---
GCP_PROJECT_ID=
GCP_REGION=southamerica-east1
